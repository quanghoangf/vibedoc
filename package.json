{
  "name": "vibedoc",
  "version": "1.0.1",
  "description": "Local-first project intelligence for AI-assisted development. Web UI + MCP server in one.",
  "bin": {
    "vibedoc": "bin/vibedoc.js"
  },
  "files": [
    "bin/",
    ".next/BUILD_ID",
    ".next/build-manifest.json",
    ".next/app-build-manifest.json",
    ".next/app-path-routes-manifest.json",
    ".next/prerender-manifest.json",
    ".next/prerender-manifest.js",
    ".next/react-loadable-manifest.json",
    ".next/routes-manifest.json",
    ".next/required-server-files.json",
    ".next/server/",
    ".next/static/",
    "public/",
    "next.config.js",
    "ws-server.js",
    "package.json"
  ],
  "scripts": {
    "dev": "concurrently \"next dev\" \"node ws-server.js\" --names \"next,ws\" --prefix-colors \"cyan,yellow\"",
    "dev:next": "next dev",
    "dev:ws": "node ws-server.js",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "prepublishOnly": "next build"
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/state": "^6.5.4",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.39.16",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@uiw/react-codemirror": "^4.25.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "glob": "^11.0.0",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.575.0",
    "marked": "^12.0.0",
    "mermaid": "^11.12.3",
    "next": "latest",
    "open": "^11.0.0",
    "react": "^19",
    "react-dom": "^19",
    "tailwind-merge": "^3.5.0",
    "ws": "^8.18.0",
    "y-codemirror.next": "^0.3.5",
    "y-websocket": "^2.1.0",
    "yjs": "^13.6.29",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.0.1",
    "concurrently": "^9.2.1",
    "eslint": "^8.57.1",
    "eslint-config-next": "latest",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
